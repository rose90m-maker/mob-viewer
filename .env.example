# Synology Docker 배포용 환경 변수
# 이 파일을 복사해서 .env 로 사용하세요: cp .env.example .env
# 절대 .env 를 Git에 커밋하지 마세요.

# === MariaDB ===
MARIADB_ROOT_PASSWORD=change_me_root_password
MARIADB_DATABASE=mobviewer
MARIADB_USER=mobviewer
MARIADB_PASSWORD=change_me_app_password

# === Backend ===
NODE_ENV=production
BACKEND_PORT=3000

# Backend가 같은 docker network 안의 mariadb 컨테이너에 접속 (호스트명 = 서비스명)
DATABASE_URL=mysql://mobviewer:change_me_app_password@mariadb:3306/mobviewer

# === JWT (앱 인증 토큰 서명용) ===
# 32자 이상의 무작위 문자열 권장. 예: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string
