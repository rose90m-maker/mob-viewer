# Synology Docker 배포용 환경 변수
# 이 파일을 복사해서 .env 로 사용하세요: cp .env.example .env
# 절대 .env 를 Git에 커밋하지 마세요.

# === Backend ===
NODE_ENV=production
BACKEND_PORT=3000

# === DATABASE (DSM MariaDB 10 패키지 사용) ===
# DSM MariaDB는 NAS 호스트에서 직접 실행 → 컨테이너에서 host.docker.internal 로 접근
# 포트는 DSM의 MariaDB 패키지 설정 화면에서 확인 (기본 3307, 본 NAS는 3306으로 변경됨)
DATABASE_URL=mysql://mobviewer:change_me_app_password@host.docker.internal:3306/mobviewer

# === JWT (앱 인증 토큰 서명용) ===
# 32자 이상의 무작위 문자열. 예: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string
